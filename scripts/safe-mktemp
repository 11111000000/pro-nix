#!/usr/bin/env bash
set -euo pipefail
# Portable safe mktemp wrapper
# Usage: safe-mktemp [-d] [TEMPLATE]
# - If -d is given, create a directory and print its path
# - TEMPLATE is passed as a suffix/prefix template (e.g. /tmp/prefix.XXXXXX or -t prefix)
# Behavior:
# 1. Prefer using XDG_RUNTIME_DIR if set and writable
# 2. Fall back to TMPDIR, then /tmp, then $HOME/.cache/tmp
# 3. Try GNU/BSD mktemp templates; if mktemp not available or fails,
#    fall back to Python's tempfile (if python3 available)

make_tmpbase() {
  local base
  if [ -n "${XDG_RUNTIME_DIR:-}" ] && [ -d "$XDG_RUNTIME_DIR" ] && [ -w "$XDG_RUNTIME_DIR" ]; then
    base="$XDG_RUNTIME_DIR"
  elif [ -n "${TMPDIR:-}" ] && [ -d "$TMPDIR" ] && [ -w "$TMPDIR" ]; then
    base="$TMPDIR"
  elif [ -d "/tmp" ] && [ -w "/tmp" ]; then
    base="/tmp"
  else
    base="$HOME/.cache/tmp"
    mkdir -p "$base" 2>/dev/null || true
  fi
  printf "%s" "$base"
}

usage() {
  cat <<'EOF' >&2
Usage: safe-mktemp [-d] [TEMPLATE]
Examples:
  safe-mktemp -d opencode.XXXXXX
  safe-mktemp /tmp/foo.XXXXXX
EOF
  exit 2
}

dir=0
template=""
while getopts ":d" opt; do
  case "$opt" in
    d) dir=1 ;;
    :) usage ;;
    *) usage ;;
  esac
done
shift $((OPTIND-1))
if [ $# -ge 1 ]; then
  template="$1"
fi

TMPBASE=$(make_tmpbase)

try_mktemp() {
  local mode="$1" tmpl="$2"
  # Try common mktemp invocation patterns
  if command -v mktemp >/dev/null 2>&1; then
    if [ "$mode" = dir ]; then
      if [ -n "$tmpl" ]; then
        mktemp -d "${TMPBASE}/${tmpl}" 2>/dev/null || mktemp -d -t "${tmpl}" 2>/dev/null || mktemp -d 2>/dev/null
      else
        mktemp -d "${TMPBASE}/tmp.XXXXXX" 2>/dev/null || mktemp -d -t "tmp" 2>/dev/null || mktemp -d 2>/dev/null
      fi
    else
      if [ -n "$tmpl" ]; then
        mktemp "${TMPBASE}/${tmpl}" 2>/dev/null || mktemp -t "${tmpl}" 2>/dev/null || mktemp 2>/dev/null
      else
        mktemp "${TMPBASE}/tmp.XXXXXX" 2>/dev/null || mktemp -t "tmp" 2>/dev/null || mktemp 2>/dev/null
      fi
    fi
  else
    return 1
  fi
}

try_python() {
  local mode="$1"
  if command -v python3 >/dev/null 2>&1; then
    if [ "$mode" = dir ]; then
      python3 - <<PY
import tempfile,sys,os
d=tempfile.mkdtemp(prefix="opencode.")
print(d)
PY
    else
      python3 - <<PY
import tempfile
f=tempfile.NamedTemporaryFile(delete=False)
print(f.name)
f.close()
PY
    fi
  else
    return 1
  fi
}

if [ "$dir" -eq 1 ]; then
  out=$(try_mktemp dir "$template" || try_python dir || (mkdir -p "${TMPBASE}/opencode.$(date +%s).$$" && printf "%s" "${TMPBASE}/opencode.$(date +%s).$$"))
else
  out=$(try_mktemp file "$template" || try_python file || (printf "%s" "${TMPBASE}/tmp.$(date +%s).$$" && touch "${TMPBASE}/tmp.$(date +%s).$$"))
fi

if [ -z "$out" ]; then
  echo "safe-mktemp: failed to create temp" >&2
  exit 1
fi

printf "%s" "$out"
