#!/usr/bin/env bash
# Simple vertical scenario test for pro-nix: verify headless Emacs starts and exits
set -euo pipefail
root="$(cd "$(dirname "$0")/../.." && pwd)"

if [ ! -f "$root/scripts/emacs-headless-test.sh" ]; then
  echo "skip: emacs-headless-test.sh not present" >&2
  exit 0
fi

echo "Running minimal vertical scenario: headless Emacs smoke"
bash "$root/scripts/emacs-headless-test.sh" || { echo "scenario failed" >&2; exit 2; }

if [ -f "$root/tests/contract/test_agent_secrets.sh" ]; then
  bash "$root/tests/contract/test_agent_secrets.sh" || { echo "agent-secrets contract failed" >&2; exit 2; }
fi

if [ -f "$root/tests/contract/test_agent_observability.sh" ]; then
  bash "$root/tests/contract/test_agent_observability.sh" || { echo "agent-observability contract failed" >&2; exit 2; }
fi

echo "scenario: OK"
