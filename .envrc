## Надёжный .envrc для flake devShell
## Поведение:
## - Предпочтительный путь: используем диренв-адресант "use flake" (современный и быстрый).
## - При отсутствии поддержки "use flake" (старый direnv / нестабильная интеграция) делаем fallback:
##   получаем переменные окружения через `nix develop --command env` и экспортируем их.
## - В случае отсутствия nix или невозможности построить окружение — выдаём понятное сообщение и прерываемся.

if [ -f flake.nix ]; then
  # Если direnv понимает директиву `use flake`, она будет выполнена и окружение установлено.
  # Используем try/catch-like конструкцию: пробуем выполнить `use flake`, но не фатально;
  # если она недоступна, переходим к fallback.
  set +e
  use flake 2>/dev/null
  rc=$?
  set -e

  if [ $rc -eq 0 ]; then
    # Успех — direnv установил flake devShell
    :
  else
    echo "direnv: 'use flake' недоступна или завершилась с ошибкой (код $rc). Попытка fallback через 'nix develop'..."
    if ! command -v nix >/dev/null 2>&1; then
      echo "Ошибка: nix не найден в PATH. Установите nix или обновите direnv."
      return 1
    fi

    # Получаем окружение от `nix develop`. Команда должна вывести набор строк VAR=VALUE.
    tmpf=$(mktemp)
    if ! nix develop --command env > "$tmpf" 2>/dev/null; then
      echo "Ошибка: не удалось получить окружение через 'nix develop'. Проверьте flake и nix.")
      rm -f "$tmpf"
      return 1
    fi

    # Преобразуем в безопасные export инструкции и source-им.
    awk -F'=' '{
      key=$1; val=substr($0, index($0, "=")+1);
      gsub(/"/, "\\\"", val);
      printf("export %s=\"%s\"\n", key, val);
    }' "$tmpf" > "$tmpf".exp
    # shellcheck disable=SC1090
    source "$tmpf".exp
    rm -f "$tmpf" "$tmpf".exp
  fi
fi
